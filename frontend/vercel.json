{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "aviation-empire.vercel.app"
        }
      ],
      "destination": "https://apronempire.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.apronempire.com"
        }
      ],
      "destination": "https://apronempire.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
